{
  "name": "runebit-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate:prod": "npx prisma migrate deploy",
    "db:seed": "node src/seed/problems.js",
    "db:reset": "npx prisma db push --force-reset && node src/seed/problems.js",
    "setup": "npm install && npx prisma generate && npx prisma db push && node src/seed/problems.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^9.0.2",
    "@prisma/client": "^6.4.1",
    "axios": "^1.8.4",
    "bcrypt": "^5.1.1",
    "fastify": "^5.3.0",
    "prisma": "^6.4.1"
  }
}
